# Copy this file to .env.local and fill in your credentials
# Never commit .env.local to git

# Intercom access token
# Get from: https://app.intercom.com/a/developer-signup → Your App → Authentication
INTERCOM_ACCESS_TOKEN=your_intercom_access_token_here

# Close CRM API key
# Get from: Close Settings → API & Webhooks → Generate API Key
CLOSE_API_KEY=your_close_api_key_here
